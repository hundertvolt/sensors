# Per-device runtime config (real WiFi credentials/hostnames) — never commit a real one.
config.json
modules/config.json

# Build output (see build-*.sh)
python/build/
firmware.uf2
*.uf2

# Local editor/OS cruft
.DS_Store
__pycache__/
*.pyc

# Dev-tooling venv (uv sync) and MicroPython stubs (scripts/typecheck.sh) - both reinstallable,
# neither meant to be committed.
.venv/
typings/

# scripts/test.sh --coverage output (see tests/README.md) - regenerated every run, not meant to
# be committed.
htmlcov/
coverage.xml
coverage_summary.md
.coverage

# Scratch config files written/removed by tests/test_config_manager.py's real file-I/O tests.
tests/_tmp/
